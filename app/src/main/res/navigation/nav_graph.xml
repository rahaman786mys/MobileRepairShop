<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Auth -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.mobilerepair.shop.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Dashboard -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.mobilerepair.shop.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <!-- New Entry Flow -->
    <fragment
        android:id="@+id/entryFragment"
        android:name="com.mobilerepair.shop.ui.entry.EntryFragment"
        android:label="New Repair Entry"
        tools:layout="@layout/fragment_entry" />

    <!-- Direct Sales -->
    <fragment
        android:id="@+id/saleFragment"
        android:name="com.mobilerepair.shop.ui.sales.SaleFragment"
        android:label="Quick Sale"
        tools:layout="@layout/fragment_sale" />

    <fragment
        android:id="@+id/inspectionFragment"
        android:name="com.mobilerepair.shop.ui.inspection.InspectionFragment"
        android:label="Inspection"
        tools:layout="@layout/fragment_inspection" />

    <fragment
        android:id="@+id/quotationFragment"
        android:name="com.mobilerepair.shop.ui.quotation.QuotationFragment"
        android:label="Quotation"
        tools:layout="@layout/fragment_quotation" />

    <fragment
        android:id="@+id/sparePartsFragment"
        android:name="com.mobilerepair.shop.ui.spareparts.SparePartsFragment"
        android:label="Spare Parts"
        tools:layout="@layout/fragment_spare_parts" />

    <fragment
        android:id="@+id/handoverFragment"
        android:name="com.mobilerepair.shop.ui.handover.HandoverFragment"
        android:label="Handover"
        tools:layout="@layout/fragment_handover" />

    <!-- Entries List -->
    <fragment
        android:id="@+id/entriesFragment"
        android:name="com.mobilerepair.shop.ui.dashboard.EntriesListFragment"
        android:label="All Entries"
        tools:layout="@layout/fragment_entries_list" />

    <!-- Reports -->
    <fragment
        android:id="@+id/reportsFragment"
        android:name="com.mobilerepair.shop.ui.reports.ReportsFragment"
        android:label="Reports"
        tools:layout="@layout/fragment_reports" />

    <!-- More / Master Data -->
    <fragment
        android:id="@+id/moreFragment"
        android:name="com.mobilerepair.shop.ui.master.MoreFragment"
        android:label="More"
        tools:layout="@layout/fragment_more" />

    <fragment
        android:id="@+id/serviceManListFragment"
        android:name="com.mobilerepair.shop.ui.master.servicemen.ServiceManListFragment"
        android:label="Service Men"
        tools:layout="@layout/fragment_service_man_list" />

    <fragment
        android:id="@+id/serviceManAddFragment"
        android:name="com.mobilerepair.shop.ui.master.servicemen.ServiceManAddFragment"
        android:label="Add Service Man"
        tools:layout="@layout/fragment_service_man_add" />

    <fragment
        android:id="@+id/supplierListFragment"
        android:name="com.mobilerepair.shop.ui.master.suppliers.SupplierListFragment"
        android:label="Suppliers"
        tools:layout="@layout/fragment_supplier_list" />

    <fragment
        android:id="@+id/supplierAddFragment"
        android:name="com.mobilerepair.shop.ui.master.suppliers.SupplierAddFragment"
        android:label="Add Supplier"
        tools:layout="@layout/fragment_supplier_add" />

    <fragment
        android:id="@+id/commonFaultsFragment"
        android:name="com.mobilerepair.shop.ui.master.faults.CommonFaultsFragment"
        android:label="Common Faults"
        tools:layout="@layout/fragment_common_faults" />

    <!-- Entry Detail / Workflow -->
    <fragment
        android:id="@+id/entryDetailFragment"
        android:name="com.mobilerepair.shop.ui.entry.EntryDetailFragment"
        android:label="Entry Details"
        tools:layout="@layout/fragment_entry_detail" />

</navigation>
