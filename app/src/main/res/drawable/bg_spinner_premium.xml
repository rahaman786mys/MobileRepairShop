<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/muzzu_surface_elevated" />
            <stroke android:width="1dp" android:color="@color/muzzu_border" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:gravity="end|center_vertical" android:right="12dp">
        <!-- Replaced vector with a safe shape-based arrow or standard drawable reference -->
        <rotate
            android:fromDegrees="45"
            android:toDegrees="45"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <size android:width="8dp" android:height="8dp" />
                <solid android:color="@color/muzzu_text_sub" />
            </shape>
        </rotate>
    </item>
</layer-list>
