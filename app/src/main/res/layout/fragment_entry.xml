<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/muzzu_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:text="New Repair Entry"
            style="@style/TextAppearance.MuZZu.Heading"
            android:layout_marginBottom="24dp" />

        <!-- Selection Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            style="@style/Widget.MuZZu.Card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:text="Select Entry Type"
                    style="@style/TextAppearance.MuZZu.Label"
                    android:layout_marginBottom="12dp" />
                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleGroupEntryType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:checkedButton="@+id/btnTypeCustomer"
                    app:singleSelection="true"
                    app:selectionRequired="true">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTypeCustomer"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Customer"
                        android:paddingVertical="12dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTypeDealer"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Dealer"
                        android:paddingVertical="12dp" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Form Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MuZZu.Card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="Contact Information"
                    style="@style/TextAppearance.MuZZu.Label"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMobile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mobile Number"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeColor="@color/muzzu_border"
                    app:prefixText="+91 "
                    app:prefixTextColor="@color/muzzu_text_sub">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMobileNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:textStyle="bold"
                        android:textColor="@color/muzzu_text_main" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Full Name"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeColor="@color/muzzu_border">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textColor="@color/muzzu_text_main" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Dynamic Repair Fields -->
                <LinearLayout
                    android:id="@+id/layoutRepairFields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/muzzu_border"
                        android:layout_marginVertical="24dp" />

                    <TextView
                        android:text="Device Details"
                        style="@style/TextAppearance.MuZZu.Label"
                        android:layout_marginBottom="16dp" />

                    <Spinner
                        android:id="@+id/spinnerBrand"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="12dp"
                        android:background="@drawable/bg_spinner_premium" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Model Name (e.g. iPhone 15 Pro)"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeColor="@color/muzzu_border">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etModelName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/muzzu_text_main" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:text="Inspection Photo"
                        style="@style/TextAppearance.MuZZu.Label"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        app:cardElevation="0dp"
                        app:cardCornerRadius="12dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/muzzu_border">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivEntryPhoto"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_plus_premium"
                            android:padding="60dp"
                            app:tint="@color/muzzu_border" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTakePhoto"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Open Camera"
                        android:textAllCaps="false" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:hint="City"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeColor="@color/muzzu_border">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/muzzu_text_main" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:text="Assign Specialist"
                        style="@style/TextAppearance.MuZZu.Label"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="12dp" />

                    <Spinner
                        android:id="@+id/spinnerServiceMan"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="12dp"
                        android:background="@drawable/bg_spinner_premium" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveEntry"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="32dp"
                        android:text="Register Entry"
                        style="@style/Widget.MuZZu.Button"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
