<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MobileRepairShop" parent="Theme.Material3.Light.NoActionBar">
        <!-- Core Colors -->
        <item name="colorPrimary">@color/muzzu_primary</item>
        <item name="colorOnPrimary">@color/muzzu_text_on_dark</item>
        <item name="colorSecondary">@color/muzzu_accent</item>
        <item name="android:windowBackground">@color/muzzu_bg</item>
        <item name="android:statusBarColor">@color/muzzu_primary</item>
        <item name="android:navigationBarColor">@color/muzzu_surface</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Global Component Styles -->
        <item name="materialCardViewStyle">@style/Widget.MuZZu.Card</item>
        <item name="materialButtonStyle">@style/Widget.MuZZu.Button</item>
    </style>

    <!-- Premium Card Style -->
    <style name="Widget.MuZZu.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/muzzu_border</item>
        <item name="cardBackgroundColor">@color/muzzu_surface</item>
    </style>

    <!-- Premium Button Style -->
    <style name="Widget.MuZZu.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Typography Hierarchy -->
    <style name="TextAppearance.MuZZu.Display" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/muzzu_text_main</item>
    </style>

    <style name="TextAppearance.MuZZu.Heading" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/muzzu_text_main</item>
    </style>

    <style name="TextAppearance.MuZZu.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/muzzu_text_sub</item>
    </style>

    <style name="TextAppearance.MuZZu.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/muzzu_text_muted</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Bottom Nav Styles -->
    <style name="BottomNavText" parent="Widget.Material3.BottomNavigationView" />

    <style name="BottomNavText.Active">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavText.Inactive">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
    </style>
</resources>
